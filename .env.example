# Example .env file
# Diese Datei liegt im Projektwurzelverzeichnis und wird vom Django-Backend
# gelesen (backend/config/settings.py). Die Keys verlassen den Server nie.
# Mindestens einen KI-Provider-Key eintragen.

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
MISTRAL_API_KEY=your-mistral-api-key
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Optional
# Standard-Provider (groq | mistral | gemini | openrouter), wenn das Frontend
# keinen anfragt. Fragt es einen an, gewinnt sein Wunsch. Leer = groq.
AI_PROVIDER=

# Port des Frontend-Servers (server.js)
PORT=3000
